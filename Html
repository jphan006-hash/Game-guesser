<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Word Guesser</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="game-container">
        <h1>AI Word Guesser</h1>
        <p id="word-display"></p>
        <p id="message-area">Enter a letter to guess the word.</p>
        <input type="text" id="guess-input" maxlength="1">
        <button id="submit-guess">Guess</button>
        <button id="get-hint">Get Hint</button>
        <p id="attempts-left">Attempts left: 6</p>
        <p id="hint-area"></p>
    </div>

    <script src="script.js"></script>
</body>
</html>
